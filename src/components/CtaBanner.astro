---
const base = import.meta.env.BASE_URL;
---

<section class="cta-banner">
  <div class="container cta-banner__content">
    <h2 class="cta-banner__headline">Not sure where to start? That's what the first meeting is for.</h2>
    <p class="cta-banner__sub">It's free, no strings attached, and takes about an hour.</p>
    <a href={`${base}contact`} class="cta-banner__btn">Book a Free Consultation</a>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--color-white, #fff);
    padding: var(--space-2xl) 0;
  }

  .cta-banner__content {
    text-align: center;
  }

  .cta-banner__headline {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
    line-height: 1.2;
  }

  .cta-banner__sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--color-gray);
    margin-bottom: var(--space-lg);
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2.5rem;
    background: var(--color-accent);
    color: var(--color-white, #fff);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 8px;
    transition: var(--transition);
  }

  .cta-banner__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 480px) {
    .cta-banner {
      padding: var(--space-xl) 0;
    }

    .cta-banner__btn {
      width: 100%;
    }
  }
</style>
