---
const base = import.meta.env.BASE_URL;
---

<section class="hero grid-bg">
  <div class="container hero__inner">
    <div class="hero__text">
      <p class="hero__eyebrow">Licensed Wealth Manager &middot; Singapore</p>
      <h1 class="hero__headline">
        I Help You<br />
        <span class="hero__gradient">Protect What Matters</span>
      </h1>
      <div class="hero__typing">
        <span class="hero__typing-text" id="typing-text"></span><span class="hero__cursor">|</span>
      </div>
      <div class="hero__cta">
        <a href={`${base}contact`} class="btn btn--primary">Book a Free Consultation</a>
        <a href={`${base}services`} class="btn btn--outline">Explore Services</a>
      </div>
    </div>

    <div class="hero__photo-wrap">
      <img
        src={`${base}janice.jpg`}
        alt="Janice Low — Licensed Wealth Manager in Singapore"
        class="hero__photo"
        width="320"
        height="320"
        loading="eager"
      />
      <p class="hero__name-badge">
        <strong>Janice Low</strong><br />
        <span>Wealth Manager</span>
      </p>
    </div>
  </div>
</section>

<style>
  /* ── Base / Mobile ─────────────────────────────── */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-navy);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
    min-height: auto;
    padding: var(--space-xl) 0;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  /* ── Photo ─────────────────────────────────────── */
  .hero__photo-wrap {
    order: -1;
    text-align: center;
  }

  .hero__photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-accent);
    box-shadow: 0 0 24px rgba(183, 148, 60, 0.25);
  }

  .hero__name-badge {
    margin-top: var(--space-xs);
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--color-gray);
  }

  .hero__name-badge strong {
    color: var(--color-white);
    font-size: 1.05rem;
  }

  /* ── Text ──────────────────────────────────────── */
  .hero__text {
    text-align: center;
  }

  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.5vw, 0.95rem);
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: var(--space-md);
  }

  .hero__headline {
    font-size: clamp(2.2rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1.08;
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .hero__gradient {
    background: linear-gradient(135deg, var(--color-accent), #D4B35A);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__typing {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-gray);
    min-height: 2rem;
    margin-bottom: var(--space-lg);
    font-weight: 400;
  }

  .hero__cursor {
    animation: blink 1s step-end infinite;
    color: var(--color-accent);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero__cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__cta .btn {
    width: 100%;
    text-align: center;
  }

  /* ── Desktop (>768px) ──────────────────────────── */
  @media (min-width: 769px) {
    .hero {
      min-height: 100vh;
      padding: 0;
    }

    .hero__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .hero__text {
      text-align: left;
      flex: 1;
      max-width: 600px;
    }

    .hero__photo-wrap {
      order: 1;
      flex-shrink: 0;
    }

    .hero__photo {
      width: 320px;
      height: 320px;
      border-radius: 1rem;
      border-width: 3px;
    }

    .hero__name-badge {
      display: none;
    }

    .hero__cta {
      flex-direction: row;
      justify-content: flex-start;
    }

    .hero__cta .btn {
      width: auto;
    }
  }
</style>

<script>
  function initTyping() {
    const el = document.getElementById('typing-text');
    if (!el) return;

    const phrases = [
      'Wealth Protection',
      'Retirement Planning',
    ];

    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;

    function tick() {
      const current = phrases[phraseIndex];

      if (!deleting) {
        el.textContent = current.slice(0, charIndex + 1);
        charIndex++;
        if (charIndex === current.length) {
          deleting = true;
          setTimeout(tick, 1800);
          return;
        }
        setTimeout(tick, 80);
      } else {
        el.textContent = current.slice(0, charIndex - 1);
        charIndex--;
        if (charIndex === 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          setTimeout(tick, 400);
          return;
        }
        setTimeout(tick, 40);
      }
    }

    el.textContent = '';
    tick();
  }

  document.addEventListener('astro:page-load', initTyping);
</script>
