---
const testimonials = [
  { quote: 'I\'m 27, BTO is coming up, and I\'m supporting my mother too. Janice helped me figure out how to balance everything — protection, savings, and still have money to live. She didn\'t judge my budget, she worked with it.', name: 'Marcus' },
  { quote: 'Janice is the real deal. No fluff, no pressure. She just gets it done.', name: 'Yandao' },
  { quote: 'As a foreigner working in Singapore, I had no idea where to start with insurance or investments here. Janice broke everything down for me and made sure I wasn\'t overpaying or missing anything important.', name: 'Lin' },
  { quote: 'I have a medical condition and was told by other agents that I couldn\'t get covered. Janice didn\'t give up — she found options I didn\'t even know existed. That meant everything to me.', name: 'Jon' },
  { quote: 'I\'m in my 50s and finally getting serious about retirement. Janice set up a proper plan and gives me monthly updates on how my investments are doing. I actually feel like someone\'s watching out for me.', name: 'D.T.' },
  { quote: 'I\'m 26 and I was honestly scared of financial advisors — thought they\'d just hard-sell me stuff. Janice was the complete opposite. She listened, explained everything, and never made me feel stupid for not knowing things.', name: 'Bryan' },
];
---

<section class="section section--dark testimonials-section">
  <div class="container">
    <h2 class="testimonials__title reveal">What Clients Say</h2>
  </div>
  <div class="testimonials__track-wrap">
    <div class="testimonials__track">
      {[...testimonials, ...testimonials].map((t) => (
        <div class="testimonials__card">
          <p class="testimonials__quote">&ldquo;{t.quote}&rdquo;</p>
          <div class="testimonials__stars">
            {Array.from({ length: 5 }).map(() => (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--color-gold)">
                <path d="M8 0l2.47 4.94L16 5.77l-4 3.86.94 5.47L8 12.67 3.06 15.1 4 9.63 0 5.77l5.53-.83z" />
              </svg>
            ))}
          </div>
          <div class="testimonials__author">
            <span class="testimonials__initials">{t.name}</span>
            <span class="testimonials__name">{t.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials__title {
    text-align: center;
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: var(--space-xl);
  }

  .testimonials__track-wrap {
    overflow: hidden;
    width: 100%;
  }

  .testimonials__track {
    display: flex;
    gap: var(--space-md);
    animation: scroll-left 40s linear infinite;
    width: max-content;
  }

  .testimonials__track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .testimonials__card {
    flex-shrink: 0;
    width: 380px;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .testimonials__quote {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-body-dark);
    flex-grow: 1;
  }

  .testimonials__stars {
    display: flex;
    gap: 4px;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .testimonials__initials {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .testimonials__name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-white);
  }

  @media (max-width: 480px) {
    .testimonials__card {
      width: 300px;
    }
  }
</style>
