---
const base = import.meta.env.BASE_URL;
---

<section class="section section--dark">
  <div class="container">
    <h2 class="services__title reveal">What I Do</h2>
    <div class="services__grid">

      <a href={`${base}services#wealth`} class="glass-card services__card reveal">
        <div class="services__icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 28 14 18 22 24 36 10" />
            <polyline points="28 10 36 10 36 18" />
          </svg>
        </div>
        <h3 class="services__card-title">Wealth Management</h3>
        <p class="services__card-desc">Strategic planning to grow and preserve your wealth across every life stage.</p>
        <span class="services__link">Learn More &rarr;</span>
      </a>

      <a href={`${base}services#insurance`} class="glass-card services__card reveal">
        <div class="services__icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 4L6 10v10c0 9 6 16 14 18 8-2 14-9 14-18V10L20 4z" />
            <polyline points="14 20 18 24 26 16" />
          </svg>
        </div>
        <h3 class="services__card-title">Insurance Advisory</h3>
        <p class="services__card-desc">Comprehensive coverage analysis to protect what matters most to you.</p>
        <span class="services__link">Learn More &rarr;</span>
      </a>

      <a href={`${base}services#investments`} class="glass-card services__card reveal">
        <div class="services__icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="22" width="6" height="12" rx="1" />
            <rect x="17" y="14" width="6" height="20" rx="1" />
            <rect x="28" y="6" width="6" height="28" rx="1" />
            <line x1="4" y1="36" x2="36" y2="36" />
          </svg>
        </div>
        <h3 class="services__card-title">Investment Management</h3>
        <p class="services__card-desc">Data-driven portfolio construction tailored to your risk profile and goals.</p>
        <span class="services__link">Learn More &rarr;</span>
      </a>

    </div>
  </div>
</section>

<style>
  .services__title {
    text-align: center;
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: var(--space-xl);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }

  .services__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-white);
  }

  .services__icon {
    color: var(--color-teal);
    margin-bottom: var(--space-xs);
  }

  .services__card-title {
    font-size: 1.35rem;
    font-weight: 600;
  }

  .services__card-desc {
    color: var(--color-body-dark);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .services__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-teal);
    margin-top: auto;
    transition: var(--transition);
  }

  .services__card:hover .services__link {
    letter-spacing: 0.02em;
  }
</style>
