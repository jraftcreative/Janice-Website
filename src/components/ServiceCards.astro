---
const base = import.meta.env.BASE_URL;
---

<section class="section section--dark">
  <div class="container">
    <h2 class="services__title reveal">What I Do</h2>
    <div class="services__grid">

      <a href={`${base}services/wealth-protection`} class="glass-card services__card reveal">
        <div class="services__icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 4L6 10v10c0 9 6 16 14 18 8-2 14-9 14-18V10L20 4z" />
            <polyline points="14 20 18 24 26 16" />
          </svg>
        </div>
        <h3 class="services__card-title">Wealth Protection</h3>
        <p class="services__card-desc">I compare all 15 insurers to build a protection plan that fits your life stage and budget — even if you have medical conditions.</p>
        <span class="services__link">Learn More &rarr;</span>
      </a>

      <a href={`${base}services/retirement-planning`} class="glass-card services__card reveal">
        <div class="services__icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 28 14 18 22 24 36 10" />
            <polyline points="28 10 36 10 36 18" />
          </svg>
        </div>
        <h3 class="services__card-title">Retirement Planning</h3>
        <p class="services__card-desc">Making your money work for you — I monitor and adjust your investment strategy as the market moves.</p>
        <span class="services__link">Learn More &rarr;</span>
      </a>

    </div>
  </div>
</section>

<style>
  .services__title {
    text-align: center;
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: var(--space-xl);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }

  .services__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-white);
  }

  .services__icon {
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .services__card-title {
    font-size: 1.35rem;
    font-weight: 600;
  }

  .services__card-desc {
    color: var(--color-body-dark);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .services__link {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-accent);
    margin-top: auto;
    transition: var(--transition);
  }

  .services__card:hover .services__link {
    letter-spacing: 0.02em;
  }
</style>
