---
const stats = [
  { value: 1, suffix: '+', label: 'Year in the Industry' },
  { value: 50, suffix: '+', label: 'Clients & Families' },
  { value: 100, suffix: '%', label: 'Client Retention' },
];
---

<section class="section section--light">
  <div class="container">
    <div class="stats reveal" id="stats-counter">
      {stats.map((stat) => (
        <div class="stats__item">
          <span class="stats__accent"></span>
          <span
            class="stats__number"
            data-target={stat.value}
            data-prefix={stat.prefix || ''}
            data-suffix={stat.suffix}
          >
            {stat.prefix || ''}{0}{stat.suffix}
          </span>
          <span class="stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-sm);
  }

  .stats__accent {
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
    margin-bottom: var(--space-xs);
  }

  .stats__number {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 400;
    color: var(--color-navy);
    font-variant-numeric: tabular-nums;
  }

  .stats__label {
    font-size: 0.9rem;
    color: var(--color-gray);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  @media (max-width: 480px) {
    .stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }

    .stats__item {
      padding: var(--space-sm) var(--space-xs);
      position: relative;
    }

    .stats__item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 20%;
      height: 60%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    }

    .stats__accent { display: none; }

    .stats__number {
      font-size: 1.75rem;
      color: var(--color-accent);
    }

    .stats__label {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  function initCounters() {
    const counters = document.querySelectorAll('.stats__number');
    let animated = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !animated) {
          animated = true;
          counters.forEach(animateCounter);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    const statsEl = document.getElementById('stats-counter');
    if (statsEl) observer.observe(statsEl);
  }

  function animateCounter(el: Element) {
    const target = parseInt((el as HTMLElement).dataset.target || '0');
    const prefix = (el as HTMLElement).dataset.prefix || '';
    const suffix = (el as HTMLElement).dataset.suffix || '';
    const duration = 2000;
    const start = performance.now();

    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = `${prefix}${current}${suffix}`;
      if (progress < 1) requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

  document.addEventListener('astro:page-load', initCounters);
</script>
