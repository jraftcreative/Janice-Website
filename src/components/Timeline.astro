---
const milestones = [
  { year: 'Aug 2025', title: 'Joined the Industry', description: 'Made the leap into financial planning — hit 5 figures in sales every single month from day one' },
  { year: 'Oct 2025', title: '6-Figure Sales', description: 'Just 3 months in and achieved 6-figure sales in a single month' },
  { year: 'Dec 2025', title: 'MDRT in 6 Months', description: 'Obtained Million Dollar Round Table qualification in just half a year — one of the fastest in the industry' },
];
---

<section class="section section--dark grid-bg timeline-section">
  <div class="container">
    <h2 class="timeline-title reveal">Career Milestones</h2>
    <div class="timeline reveal">
      <div class="timeline__track">
        <div class="timeline__line" aria-hidden="true"></div>
        {milestones.map((m) => (
          <div class="timeline__item" tabindex="0">
            <div class="timeline__dot"></div>
            <span class="timeline__date">{m.year}</span>
            <h3 class="timeline__heading">{m.title}</h3>
            <div class="timeline__detail">
              <p>{m.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-xl);
  }

  .timeline__track {
    display: flex;
    justify-content: space-between;
    position: relative;
    padding-top: var(--space-lg);
  }

  .timeline__line {
    position: absolute;
    top: calc(var(--space-lg) + 6px);
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--color-accent), var(--color-accent), transparent);
  }

  .timeline__item {
    position: relative;
    flex: 1;
    text-align: center;
    padding: 0 var(--space-sm);
    cursor: pointer;
    outline: none;
  }

  .timeline__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid var(--color-navy);
    box-shadow: 0 0 12px rgba(184, 146, 63, 0.3);
    margin: 0 auto var(--space-sm);
    position: relative;
    z-index: 1;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline__date {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .timeline__heading {
    font-size: 1rem;
    color: var(--color-white);
    margin-bottom: 0;
    transition: color 0.3s ease;
  }

  .timeline__detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.3s ease, margin 0.3s ease;
    opacity: 0;
    margin-top: 0;
  }

  .timeline__detail p {
    font-size: 0.9rem;
    color: var(--color-body-dark);
    line-height: 1.5;
    padding-top: var(--space-xs);
  }

  /* Hover / focus expand */
  .timeline__item:hover .timeline__detail,
  .timeline__item:focus .timeline__detail {
    max-height: 200px;
    opacity: 1;
    margin-top: var(--space-xs);
  }

  .timeline__item:hover .timeline__dot,
  .timeline__item:focus .timeline__dot {
    transform: scale(1.4);
    box-shadow: 0 0 20px rgba(184, 146, 63, 0.5);
  }

  .timeline__item:hover .timeline__heading,
  .timeline__item:focus .timeline__heading {
    color: var(--color-accent);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .timeline__track {
      flex-direction: column;
      padding-top: 0;
      padding-left: var(--space-lg);
    }

    .timeline__line {
      top: 0;
      bottom: 0;
      left: 6px;
      right: auto;
      width: 2px;
      height: auto;
      background: linear-gradient(to bottom, transparent, var(--color-accent), var(--color-accent), transparent);
    }

    .timeline__item {
      text-align: left;
      padding: 0 0 var(--space-lg) var(--space-md);
    }

    .timeline__dot {
      position: absolute;
      left: calc(-1 * var(--space-lg) + -1px);
      top: 2px;
      margin: 0;
    }

    .timeline__detail {
      max-height: none;
      opacity: 1;
      margin-top: var(--space-xs);
    }
  }
</style>
