---
const milestones = [
  { year: 'Aug 2025', title: 'Joined the Industry', description: 'Made the leap into financial planning — hit 5 figures in sales every single month from day one' },
  { year: 'Oct 2025', title: '6-Figure Sales', description: 'Just 3 months in and achieved 6-figure sales in a single month' },
  { year: 'Dec 2025', title: 'MDRT in 6 Months', description: 'Obtained Million Dollar Round Table qualification in just half a year — one of the fastest in the industry' },
];
---

<section class="section section--dark grid-bg timeline-section">
  <div class="container">
    <h2 class="timeline-title reveal">Career Milestones</h2>
    <div class="timeline">
      {milestones.map((m, i) => (
        <div class={`timeline-entry ${i % 2 === 0 ? 'timeline-entry--left' : 'timeline-entry--right'} reveal`}>
          <div class="timeline-entry__content glass-card">
            <span class="timeline-entry__year">{m.year}</span>
            <h3 class="timeline-entry__title">{m.title}</h3>
            <p class="timeline-entry__desc">{m.description}</p>
          </div>
          <div class="timeline-entry__dot"></div>
        </div>
      ))}
      <div class="timeline-line" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .timeline-title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-xl);
  }

  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    transform: translateX(-50%);
  }

  .timeline-entry {
    position: relative;
    width: 50%;
    padding: 0 var(--space-lg) var(--space-xl);
  }

  .timeline-entry--left {
    left: 0;
    text-align: right;
    padding-right: var(--space-xl);
  }

  .timeline-entry--right {
    left: 50%;
    text-align: left;
    padding-left: var(--space-xl);
  }

  .timeline-entry__dot {
    position: absolute;
    top: 8px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid var(--color-navy);
    box-shadow: 0 0 12px rgba(184, 146, 63, 0.3);
    z-index: 1;
  }

  .timeline-entry--left .timeline-entry__dot {
    right: calc(-7px);
  }

  .timeline-entry--right .timeline-entry__dot {
    left: calc(-7px);
  }

  .timeline-entry__content {
    text-align: left;
  }

  .timeline-entry--left .timeline-entry__content {
    text-align: right;
  }

  .timeline-entry__year {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .timeline-entry__title {
    font-size: 1.15rem;
    margin: var(--space-xs) 0;
    color: var(--color-white);
  }

  .timeline-entry__desc {
    font-size: 0.95rem;
    color: var(--color-body-dark);
    line-height: 1.5;
  }

  /* Mobile: horizontal row with hover expand */
  @media (max-width: 768px) {
    .timeline {
      max-width: none;
    }

    .timeline-line {
      left: 0;
      right: 0;
      top: calc(var(--space-lg) + 6px);
      bottom: auto;
      width: auto;
      height: 2px;
      transform: none;
      background: linear-gradient(to right, transparent, var(--color-accent), var(--color-accent), transparent);
    }

    .timeline-entry,
    .timeline-entry--left,
    .timeline-entry--right {
      width: auto;
      left: 0;
      display: inline-block;
      text-align: center;
      padding: 0;
      vertical-align: top;
    }

    .timeline {
      display: flex;
      padding-top: var(--space-lg);
    }

    .timeline-entry {
      flex: 1;
      padding: 0 var(--space-xs);
    }

    .timeline-entry__dot {
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      margin: 0 auto var(--space-sm);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .timeline-entry--left .timeline-entry__dot,
    .timeline-entry--right .timeline-entry__dot {
      left: auto;
      right: auto;
    }

    .timeline-entry__content {
      text-align: center;
      background: none;
      border: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      padding: 0;
    }

    .timeline-entry__content:hover {
      border-color: transparent;
      box-shadow: none;
    }

    .timeline-entry--left .timeline-entry__content {
      text-align: center;
    }

    .timeline-entry__desc {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.4s ease, opacity 0.3s ease;
      font-size: 0.85rem;
    }

    .timeline-entry:hover .timeline-entry__desc,
    .timeline-entry:focus-within .timeline-entry__desc {
      max-height: 200px;
      opacity: 1;
    }

    .timeline-entry:hover .timeline-entry__dot,
    .timeline-entry:focus-within .timeline-entry__dot {
      transform: scale(1.4);
      box-shadow: 0 0 20px rgba(184, 146, 63, 0.5);
    }

    .timeline-entry:hover .timeline-entry__title,
    .timeline-entry:focus-within .timeline-entry__title {
      color: var(--color-accent);
    }

    .timeline-entry__title {
      transition: color 0.3s ease;
      font-size: 0.95rem;
    }

    .timeline-entry__year {
      font-size: 0.75rem;
    }
  }
</style>
