---
const milestones = [
  { year: 'Aug 2025', title: 'Joined the Industry', description: 'Made the leap into financial planning — hit 5 figures in sales every single month from day one' },
  { year: 'Oct 2025', title: '6-Figure Sales', description: 'Just 3 months in and achieved 6-figure sales in a single month' },
  { year: 'Dec 2025', title: 'MDRT in 6 Months', description: 'Obtained Million Dollar Round Table qualification in just half a year — one of the fastest in the industry' },
];
---

<section class="section section--light timeline-section">
  <div class="container">
    <h2 class="timeline-title reveal">Career Milestones</h2>
    <div class="timeline reveal">
      <div class="timeline__line" aria-hidden="true"></div>
      {milestones.map((m) => (
        <div class="timeline__item">
          <div class="timeline__dot"></div>
          <span class="timeline__date">{m.year}</span>
          <h3 class="timeline__heading">{m.title}</h3>
          <div class="timeline__detail">
            <p>{m.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-xl);
    color: var(--color-dark-text);
  }

  /* Desktop: horizontal */
  .timeline {
    display: flex;
    justify-content: space-between;
    position: relative;
    padding-top: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline__line {
    position: absolute;
    top: calc(var(--space-lg) + 6px);
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--color-accent), var(--color-accent), transparent);
  }

  .timeline__item {
    position: relative;
    flex: 1;
    text-align: center;
    padding: 0 var(--space-sm);
  }

  .timeline__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid #fff;
    box-shadow: 0 0 12px rgba(184, 146, 63, 0.3);
    margin: 0 auto var(--space-sm);
    position: relative;
    z-index: 1;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline__date {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .timeline__heading {
    font-size: 1rem;
    color: var(--color-dark-text);
    margin-bottom: 0;
    transition: color 0.3s ease;
  }

  .timeline__detail {
    margin-top: var(--space-xs);
  }

  .timeline__detail p {
    font-size: 0.9rem;
    color: #4A5568;
    line-height: 1.5;
    padding-top: var(--space-xs);
  }


  /* Mobile: vertical left-aligned */
  @media (max-width: 768px) {
    .timeline {
      flex-direction: column;
      padding-top: 0;
      padding-left: var(--space-lg);
    }

    .timeline__line {
      top: 0;
      bottom: 0;
      left: 6px;
      right: auto;
      width: 2px;
      height: auto;
      background: linear-gradient(to bottom, transparent, var(--color-accent), var(--color-accent), transparent);
    }

    .timeline__item {
      text-align: left;
      padding: 0 0 var(--space-lg) var(--space-md);
    }

    .timeline__dot {
      position: absolute;
      left: calc(-1 * var(--space-lg) + -1px);
      top: 2px;
      margin: 0;
    }

    .timeline__detail {
      max-height: none;
      opacity: 1;
    }

    .timeline__heading {
      font-size: 1.1rem;
      margin-bottom: var(--space-xs);
    }
  }
</style>
