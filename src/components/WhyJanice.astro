---
const base = import.meta.env.BASE_URL;
const differentiators = [
  {
    title: 'MAS Licensed & Regulated',
    desc: 'MAS Representative No. LJ-300855233 — look me up on the Financial Advisers Public Register anytime',
  },
  {
    title: 'No Hard-Sell, Ever',
    desc: 'I compare all 15 insurers to find what genuinely fits your situation and budget — not what pays me the most',
  },
  {
    title: 'Single Mother Who Gets It',
    desc: 'I\'ve been through retrenchment and financial vulnerability firsthand. I understand what it feels like to worry about money',
  },
  {
    title: 'I Don\'t Disappear',
    desc: 'Monthly investment updates, frequent check-ins, and I actually reply on WhatsApp — I stay in your corner long after the paperwork is signed',
  },
];
---

<section class="section section--light">
  <div class="container">
    <h2 class="why__title reveal">Why Work With Me</h2>
    <div class="why__grid">
      <div class="why__list">
        {differentiators.map((d) => (
          <div class="why__item reveal">
            <div class="why__check">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 12 9 17 20 6" />
              </svg>
            </div>
            <div>
              <h3 class="why__item-title">{d.title}</h3>
              <p class="why__item-desc">{d.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="why__photo-wrap reveal">
        <img src={`${base}janice.jpg`} alt="Janice Low" class="why__photo" width="300" height="400" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .why__title {
    text-align: center;
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: var(--space-xl);
    color: var(--color-navy);
  }

  .why__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (max-width: 768px) {
    .why__grid {
      grid-template-columns: 1fr;
    }

    .why__photo-wrap {
      display: flex;
      justify-content: center;
    }
  }

  .why__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .why__item {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  .why__check {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border-radius: 50%;
    margin-top: 2px;
  }

  .why__item-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.25rem;
  }

  .why__item-desc {
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: 1.5;
  }

  .why__photo {
    width: 300px;
    max-width: 100%;
    height: 400px;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--border-radius);
    border: 3px solid var(--color-accent);
  }
</style>
