---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import CtaBanner from '../components/CtaBanner.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Services" description="Financial planning services in Singapore: wealth management, insurance reviews, and investment advice. CPF, SRS, and MAS-regulated.">

  <!-- Hero -->
  <section class="section section--dark grid-bg services-hero">
    <div class="container">
      <div class="services-hero__content reveal">
        <h1 class="services-hero__title">What I Actually Do (And Don't Do)</h1>
        <p class="services-hero__subtitle">No jargon, no hard sell. Here's how I help clients in Singapore manage their money.</p>
      </div>
    </div>
  </section>

  <!-- Wealth Management -->
  <section id="wealth" class="section section--light">
    <div class="container service-row reveal">
      <div class="service-row__text">
        <span class="service-row__label">01</span>
        <h2 class="service-row__title">Wealth Management</h2>
        <p class="service-row__desc">Most people I meet have bits and pieces — some CPF here, an endowment plan there, maybe an SRS account they opened but never really used. I help you connect the dots so everything works together toward the life you're actually planning for.</p>
        <ul class="service-row__list">
          <li>CPF optimization (OA, SA, MA, RA)</li>
          <li>Retirement income planning</li>
          <li>Estate planning & lasting power of attorney</li>
          <li>SRS contributions & tax relief</li>
        </ul>
        <a href={`${base}contact`} class="btn btn--primary">Get Started</a>
      </div>
      <div class="service-row__visual">
        <div class="visual-container visual-container--dark">
          <svg class="chart-svg" viewBox="0 0 280 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <polyline
              class="chart-line"
              points="20,130 60,110 100,120 140,80 180,90 220,50 260,30"
              stroke="var(--color-accent)"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
            <polyline
              points="20,130 60,110 100,120 140,80 180,90 220,50 260,30 260,140 20,140"
              fill="url(#tealGrad)"
              opacity="0.15"
            />
            <defs>
              <linearGradient id="tealGrad" x1="140" y1="30" x2="140" y2="140" gradientUnits="userSpaceOnUse">
                <stop stop-color="var(--color-accent)" />
                <stop offset="1" stop-color="var(--color-accent)" stop-opacity="0" />
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Insurance Advisory -->
  <section id="insurance" class="section section--dark">
    <div class="container service-row service-row--reversed reveal">
      <div class="service-row__text">
        <span class="service-row__label">02</span>
        <h2 class="service-row__title">Insurance Advisory</h2>
        <p class="service-row__desc">A lot of people are either over-insured in areas they don't need, or have major gaps they don't know about. I do a full review of what you have, explain what's actually useful, and help you trim or fill where it matters.</p>
        <ul class="service-row__list">
          <li>Term life & whole life coverage</li>
          <li>Critical illness (early & multi-pay plans)</li>
          <li>Disability income protection</li>
          <li>Integrated Shield Plans & riders</li>
        </ul>
        <a href={`${base}contact`} class="btn btn--outline">Get Started</a>
      </div>
      <div class="service-row__visual">
        <div class="visual-container visual-container--transparent">
          <svg class="shield-svg" viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path
              class="shield-outline"
              d="M60 10 L105 35 L105 75 C105 100 85 120 60 130 C35 120 15 100 15 75 L15 35 Z"
              stroke="var(--color-accent)"
              stroke-width="2.5"
              fill="none"
              stroke-linejoin="round"
            />
            <polyline
              class="shield-check"
              points="40,72 54,86 82,58"
              stroke="var(--color-accent)"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Investment Management -->
  <section id="investments" class="section section--light">
    <div class="container service-row reveal">
      <div class="service-row__text">
        <span class="service-row__label">03</span>
        <h2 class="service-row__title">Investment Management</h2>
        <p class="service-row__desc">I build portfolios based on how long you're investing for and how much volatility you can actually stomach — not what's trending on forums. Everything is MAS-compliant, and I rebalance regularly so you don't have to watch the market daily.</p>
        <ul class="service-row__list">
          <li>Diversified fund portfolios</li>
          <li>Risk-appropriate asset allocation</li>
          <li>SRS & CPF-IS investment options</li>
          <li>Quarterly rebalancing & reviews</li>
        </ul>
        <a href={`${base}contact`} class="btn btn--primary">Get Started</a>
      </div>
      <div class="service-row__visual">
        <div class="visual-container visual-container--dark">
          <svg class="bars-svg" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect class="bar bar--1" x="25" y="100" width="30" rx="4" height="50" fill="var(--color-accent)" opacity="0.7" />
            <rect class="bar bar--2" x="65" y="70" width="30" rx="4" height="80" fill="var(--color-accent)" opacity="0.8" />
            <rect class="bar bar--3" x="105" y="45" width="30" rx="4" height="105" fill="var(--color-accent)" opacity="0.9" />
            <rect class="bar bar--4" x="145" y="20" width="30" rx="4" height="130" fill="var(--color-accent)" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Flow -->
  <ProcessFlow />

  <!-- CTA Banner -->
  <CtaBanner />

</BaseLayout>

<style>
  /* ── Hero ── */
  .services-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
  }

  .services-hero__title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
    margin-bottom: var(--space-sm);
  }

  .services-hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-gray);
    max-width: 540px;
    margin: 0 auto;
  }

  /* ── Service Row ── */
  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .service-row--reversed {
    direction: rtl;
  }

  .service-row--reversed > * {
    direction: ltr;
  }

  .service-row__label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .service-row__title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    margin-bottom: var(--space-sm);
  }

  .service-row__desc {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .section--dark .service-row__desc {
    color: var(--color-body-dark);
  }

  .service-row__list {
    list-style: none;
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .service-row__list li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 1rem;
  }

  .service-row__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* ── Visual Containers ── */
  .service-row__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-container {
    border-radius: var(--border-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    width: 100%;
    max-width: 360px;
    aspect-ratio: 4 / 3;
  }

  .visual-container--dark {
    background: var(--color-navy);
    border: 1px solid var(--glass-border);
  }

  .visual-container--transparent {
    background: rgba(184, 146, 63, 0.06);
    border: 1px solid var(--glass-border);
  }

  .chart-svg,
  .bars-svg {
    width: 100%;
    height: auto;
  }

  .shield-svg {
    width: 120px;
    height: auto;
  }

  /* ── Line Chart Animation ── */
  .chart-line {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
  }

  .visible .chart-line {
    animation: drawLine 1.5s ease forwards 0.3s;
  }

  @keyframes drawLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* ── Shield Pulse Animation ── */
  .shield-outline {
    filter: drop-shadow(0 0 6px rgba(184, 146, 63, 0.3));
  }

  .visible .shield-outline {
    animation: pulse 2.5s ease-in-out infinite;
  }

  .shield-check {
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
  }

  .visible .shield-check {
    animation: drawLine 0.8s ease forwards 0.4s;
  }

  @keyframes pulse {
    0%, 100% {
      filter: drop-shadow(0 0 6px rgba(184, 146, 63, 0.3));
    }
    50% {
      filter: drop-shadow(0 0 18px rgba(184, 146, 63, 0.3));
    }
  }

  /* ── Bar Chart Animation ── */
  .bar {
    transform-origin: bottom;
    transform: scaleY(0);
  }

  .visible .bar--1 { animation: growBar 0.6s ease forwards 0.2s; }
  .visible .bar--2 { animation: growBar 0.6s ease forwards 0.35s; }
  .visible .bar--3 { animation: growBar 0.6s ease forwards 0.5s; }
  .visible .bar--4 { animation: growBar 0.6s ease forwards 0.65s; }

  @keyframes growBar {
    to {
      transform: scaleY(1);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .service-row {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .service-row--reversed {
      direction: ltr;
    }

    .service-row__visual {
      order: -1;
    }

    .service-row--reversed .service-row__visual {
      order: -1;
    }

    .visual-container {
      max-width: 280px;
      padding: var(--space-lg);
    }
  }
</style>
