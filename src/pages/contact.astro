---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const faqItems = [
  {
    question: "Do I need a lot of money before I can start financial planning?",
    answer: "Not at all. Some of my clients are in their 20s just starting out. Financial planning isn't about how much you have — it's about making the most of what you do have. I work with your actual budget to build something realistic."
  },
  {
    question: "Are you going to push products on me?",
    answer: "No. I compare all 15 insurers to find what genuinely fits your situation. If something doesn't make sense for you, I'll tell you — even if it means I don't earn a commission. I'd rather have your trust than a quick sale."
  },
  {
    question: "I'm still young, do I really need to think about insurance or investments now?",
    answer: "Actually, the younger you start, the cheaper and easier it is. Premiums are lower when you're healthy, and investments have more time to grow. I work with a lot of clients in their 20s who are glad they started early."
  },
  {
    question: "What if I don't understand anything about finance?",
    answer: "That's completely fine — most people don't, and that's nothing to be embarrassed about. I explain everything in plain English, no jargon. If something doesn't make sense, just ask. I'd rather you fully understand your plan than just nod along."
  },
  {
    question: "How do I know if the plan you recommend is suitable for me?",
    answer: "I spend a lot of time understanding your full picture — income, expenses, goals, family situation, risk appetite. I don't do cookie-cutter plans. Everything I recommend is built specifically around your life, and I'll walk you through the reasoning behind every suggestion."
  },
  {
    question: "What happens after I become your client?",
    answer: "I don't disappear after the paperwork. I send monthly investment updates, check in regularly, and I'm always reachable on WhatsApp. If your life situation changes — new job, marriage, baby — we adjust the plan together."
  }
];
---

<BaseLayout title="Contact" description="Get in touch with Janice Low, licensed wealth manager in Singapore. Book a free consultation to discuss your financial goals.">

  <!-- Hero + Split Layout (single dark section) -->
  <section class="section section--dark grid-bg contact-hero">
    <div class="container">
      <!-- Hero -->
      <div class="contact-hero__text reveal">
        <h1 class="contact-hero__title">Let's Have a Conversation</h1>
        <p class="contact-hero__subtitle">No pitch deck, no pressure. Just tell me what's on your mind and we'll go from there.</p>
      </div>

      <!-- Split Layout -->
      <div class="contact-split reveal">
        <!-- Left: Form -->
        <div class="contact-split__form">
          <ContactForm />
        </div>

        <!-- Right: Info Panel -->
        <div class="contact-split__info">
          <!-- WhatsApp -->
          <div class="contact-info__block">
            <div class="contact-info__heading">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-info__icon">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
              </svg>
              <h3>WhatsApp Me</h3>
            </div>
            <p class="contact-info__text">Fastest way to reach me — just drop a message.</p>
            <a href="https://wa.me/6580797449" target="_blank" rel="noopener noreferrer" class="btn btn--outline contact-info__btn">Chat on WhatsApp</a>
          </div>

          <hr class="contact-info__divider" />

          <!-- Contact Details -->
          <div class="contact-info__block">
            <div class="contact-info__row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-info__icon">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <span>Singapore</span>
            </div>
            <div class="contact-info__row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-info__icon">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <a href="mailto:janice.low@sg-alliance.com">janice.low@sg-alliance.com</a>
            </div>
            <div class="contact-info__row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-info__icon">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
              <a href="tel:+6580797449">+65 8079 7449</a>
            </div>
          </div>

          <hr class="contact-info__divider" />

          <!-- Office Hours -->
          <div class="contact-info__block">
            <h4 class="contact-info__label">Office Hours</h4>
            <p class="contact-info__text">Monday &ndash; Friday: 9:00 AM &ndash; 6:00 PM</p>
            <p class="contact-info__text">Saturday: By appointment</p>
            <p class="contact-info__text">Sunday: Closed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section section--light contact-faq">
    <div class="container">
      <div class="contact-faq__header reveal">
        <h2 class="contact-faq__title">Frequently Asked Questions</h2>
        <p class="contact-faq__subtitle">Things people usually ask before the first meeting.</p>
      </div>
      <div class="reveal">
        <FAQAccordion items={faqItems} />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .contact-hero__text {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .contact-hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: var(--space-sm);
  }

  .contact-hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--color-gray);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Split Layout ── */
  .contact-split {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-split {
      grid-template-columns: 1fr;
    }
  }

  /* ── Info Panel ── */
  .contact-split__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contact-info__block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact-info__heading {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .contact-info__heading h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-white);
  }

  .contact-info__icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .contact-info__text {
    font-size: 0.95rem;
    color: var(--color-body-dark);
    line-height: 1.6;
  }

  .contact-info__btn {
    align-self: flex-start;
  }

  .contact-info__divider {
    border: none;
    border-top: 1px solid rgba(148, 163, 184, 0.15);
  }

  .contact-info__row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    color: var(--color-body-dark);
  }

  .contact-info__row a {
    color: var(--color-body-dark);
    transition: var(--transition);
  }

  .contact-info__row a:hover {
    color: var(--color-accent);
  }

  .contact-info__label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── FAQ Section ── */
  .contact-faq__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .contact-faq__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-sm);
    color: var(--color-dark-text);
  }

  .contact-faq__subtitle {
    font-size: 1.05rem;
    color: var(--color-gray);
  }
</style>
