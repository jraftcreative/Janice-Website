---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import CtaBanner from '../components/CtaBanner.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About" description="Learn about Janice Low — from HR professional and single mother to licensed wealth manager in Singapore. MAS regulated, MDRT qualified in just 6 months.">

  <!-- Hero + Story -->
  <section class="section section--dark grid-bg about-hero">
    <div class="container about-hero__grid">
      <div class="about-hero__text reveal">
        <h1 class="about-hero__title">About Janice</h1>
        <p class="about-hero__subtitle">Licensed Wealth Manager &middot; SG Alliance — Wealth Prestige</p>
        <div class="about-hero__story">
          <h2 class="about-hero__story-title">How I Got Here</h2>
          <p>For years I worked in HR — stable job, decent pay, the kind of life that looks fine on paper. Then everything changed at once. I got retrenched. I went through a divorce. Suddenly I was a single mother of two with no safety net, trying to figure out how to keep things together.</p>
          <p>That period was the hardest of my life, but it taught me something important: financial vulnerability is terrifying, and most people don't have anyone in their corner helping them prepare for it. I wanted to be that person for others.</p>
          <p>So I made the leap into financial planning. I studied for my M9, M9A, HI, and RES5 certifications, earned my Wealth Manager qualification, and joined SG Alliance — Wealth Prestige. Within 6 months, I qualified for MDRT. Not because I'm a hard-seller — because I genuinely care about getting it right for every client.</p>
        </div>
      </div>
      <div class="about-hero__photo-wrap reveal">
        <img src={`${base}janice.jpg`} alt="Janice Low — Wealth Manager" class="about-hero__photo" width="280" height="360" loading="eager" />
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <Timeline />

  <!-- Philosophy -->
  <section class="section section--dark about-philosophy">
    <div class="container">
      <div class="glass-card about-philosophy__card reveal">
        <span class="about-philosophy__quote-mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="about-philosophy__quote">
          I've been in a position where I had nothing. I know what it's like to worry about money. That's why I'll never hard-sell you anything. I compare all 15 insurers, I find what genuinely fits, and if something doesn't make sense for you, I'll say so — even if it means I don't earn a commission.
        </blockquote>
        <cite class="about-philosophy__cite">— Janice Low</cite>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="section section--light about-credentials">
    <div class="container">
      <h2 class="about-credentials__title reveal">Credentials &amp; Qualifications</h2>
      <div class="about-credentials__grid">
        <div class="about-credentials__card reveal">
          <div class="about-credentials__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="4" width="36" height="40" rx="3" stroke="currentColor" stroke-width="2"/>
              <path d="M14 16h20M14 22h20M14 28h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <circle cx="36" cy="36" r="10" fill="#1B365D" stroke="currentColor" stroke-width="2"/>
              <path d="M32 36l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="about-credentials__abbr">M9 / M9A</span>
          <h3>Life Insurance & Investment-Linked</h3>
          <p>Licensed to advise on life insurance products and investment-linked plans in Singapore</p>
        </div>
        <div class="about-credentials__card reveal">
          <div class="about-credentials__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M24 4L6 14v12c0 11.1 7.68 21.48 18 24 10.32-2.52 18-12.9 18-24V14L24 4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <rect x="20" y="16" width="8" height="16" rx="1" stroke="currentColor" stroke-width="2"/>
              <rect x="16" y="20" width="16" height="8" rx="1" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
          <span class="about-credentials__abbr">HI</span>
          <h3>Health Insurance</h3>
          <p>Certified to advise on health insurance including Integrated Shield Plans and riders</p>
        </div>
        <div class="about-credentials__card about-credentials__card--logo reveal">
          <img src={`${base}logos/MAS%20Logo.jpeg`} alt="Monetary Authority of Singapore" class="about-credentials__logo" width="80" height="80" loading="lazy" />
          <h3>MAS Representative</h3>
          <p>MAS No. LJ-300855233 — regulated by the Monetary Authority of Singapore</p>
        </div>
        <div class="about-credentials__card about-credentials__card--logo reveal">
          <img src={`${base}logos/MDRT.png`} alt="Million Dollar Round Table" class="about-credentials__logo" width="80" height="80" loading="lazy" />
          <h3>Million Dollar Round Table</h3>
          <p>Qualified in just 6 months — recognised among the top financial professionals globally</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Personal Touch -->
  <section class="section section--dark about-personal">
    <div class="container about-personal__grid reveal">
      <div class="about-personal__text">
        <h2 class="about-personal__title">Beyond the Numbers</h2>
        <p>When I'm not working, you'll probably find me at a rock climbing gym or bouldering wall — it's how I clear my head. I love going to concerts, and I travel whenever I can. I'm also a single mother of two, which honestly makes me a better advisor. I understand what it's like to juggle everything, worry about the future, and just want to know your family is going to be okay.</p>
      </div>
      <div class="about-personal__carousel" id="personal-carousel">
        <div class="about-personal__track" id="personal-track">
          <img src={`${base}personal/1.jpg`} alt="Rock climbing" class="about-personal__slide" loading="lazy" />
          <img src={`${base}personal/2.jpg`} alt="Bouldering" class="about-personal__slide" loading="lazy" />
          <img src={`${base}personal/3.jpg`} alt="Working out at the gym" class="about-personal__slide" loading="lazy" />
          <img src={`${base}personal/4.jpg`} alt="Travelling" class="about-personal__slide" loading="lazy" />
        </div>
        <div class="about-personal__dots" id="personal-dots">
          <button class="about-personal__dot active" aria-label="Slide 1"></button>
          <button class="about-personal__dot" aria-label="Slide 2"></button>
          <button class="about-personal__dot" aria-label="Slide 3"></button>
          <button class="about-personal__dot" aria-label="Slide 4"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner />
</BaseLayout>

<style>
  /* ── Hero + Story ── */
  .about-hero__grid {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-xl);
  }

  .about-hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: var(--space-sm);
  }

  .about-hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    color: var(--color-accent);
  }

  .about-hero__story {
    margin-top: var(--space-lg);
  }

  .about-hero__story-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .about-hero__story p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-body-dark);
    margin-bottom: var(--space-md);
  }

  .about-hero__photo {
    width: 380px;
    height: 500px;
    border-radius: var(--border-radius);
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .about-hero__photo-wrap {
    position: relative;
    border-radius: var(--border-radius);
    padding: 2px;
    background: linear-gradient(135deg, var(--color-accent), rgba(184, 146, 63, 0.3));
  }

  @media (max-width: 768px) {
    .about-hero__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    /* Show photo first on mobile */
    .about-hero__photo-wrap {
      margin: 0 auto;
      position: static;
      order: -1;
    }

    .about-hero__photo {
      width: 180px;
      max-width: 100%;
      height: 230px;
    }

    .about-hero__title {
      font-size: 2rem;
      margin-top: var(--space-md);
    }

    .about-hero__subtitle {
      font-size: 0.85rem;
    }

    .about-hero__story {
      text-align: left;
      margin-top: var(--space-md);
    }

    .about-hero__story-title {
      font-size: 1.25rem;
      margin-bottom: var(--space-sm);
    }

    .about-hero__story p {
      font-size: 0.9rem;
      line-height: 1.7;
      margin-bottom: var(--space-sm);
    }
  }

  /* ── Philosophy ── */
  .about-philosophy__card {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-xl);
    position: relative;
  }

  .about-philosophy__quote-mark {
    font-size: 5rem;
    font-family: Georgia, serif;
    color: var(--color-accent);
    line-height: 1;
    display: block;
    margin-bottom: var(--space-sm);
    opacity: 0.6;
  }

  .about-philosophy__quote {
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    color: var(--color-body-dark);
    font-style: italic;
    border: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
  }

  .about-philosophy__cite {
    font-family: var(--font-body);
    font-style: normal;
    color: var(--color-accent);
    font-size: 1rem;
  }

  /* ── Credentials ── */
  .about-credentials__title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-xl);
    color: var(--color-dark-text);
  }

  .about-credentials__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .about-credentials__card {
    background: var(--color-white);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    border-top: 3px solid var(--color-accent);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: var(--transition);
  }

  .about-credentials__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .about-credentials__icon {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .about-credentials__card--logo {
    text-align: center;
    align-items: center;
  }

  .about-credentials__logo {
    width: 80px;
    height: 80px;
    object-fit: contain;
    display: block;
    margin: 0 auto var(--space-sm);
    border-radius: 8px;
    mix-blend-mode: multiply;
  }

  .about-credentials__abbr {
    font-family: var(--font-body);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-accent);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .about-credentials__card h3 {
    font-size: 1.05rem;
    margin-bottom: var(--space-xs);
    color: var(--color-dark-text);
  }

  .about-credentials__card p {
    font-size: 0.9rem;
    color: #64748B;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .about-credentials__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .about-credentials__grid {
      grid-template-columns: 1fr;
    }

    .about-credentials__card {
      padding: var(--space-md);
    }
  }

  /* ── Philosophy mobile ── */
  @media (max-width: 768px) {
    .about-philosophy__card {
      padding: var(--space-lg);
    }

    .about-philosophy__quote-mark {
      font-size: 3rem;
    }
  }

  /* ── Personal Touch ── */
  .about-personal__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .about-personal__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-md);
  }

  .about-personal__text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-body-dark);
  }

  /* Carousel */
  .about-personal__carousel {
    position: relative;
    overflow: hidden;
    border-radius: var(--border-radius);
    max-width: 400px;
    margin: 0 auto;
  }

  .about-personal__track {
    display: flex;
    transition: transform 0.5s ease;
  }

  .about-personal__slide {
    width: 100%;
    flex-shrink: 0;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--border-radius);
  }

  .about-personal__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-top: var(--space-sm);
  }

  .about-personal__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: var(--transition);
  }

  .about-personal__dot.active {
    background: var(--color-accent);
    transform: scale(1.3);
  }

  @media (max-width: 768px) {
    .about-personal__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .about-personal__carousel {
      max-width: 360px;
      margin: 0 auto;
    }
  }
</style>

<script>
  function initPersonalCarousel() {
    const track = document.getElementById('personal-track');
    const dots = document.querySelectorAll('.about-personal__dot');
    if (!track || !dots.length) return;

    let current = 0;
    const total = dots.length;

    function goTo(index: number) {
      current = index;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => {
      goTo(i);
    }));

    // Auto-swipe every 4 seconds
    setInterval(() => goTo((current + 1) % total), 4000);
  }

  document.addEventListener('astro:page-load', initPersonalCarousel);
</script>
